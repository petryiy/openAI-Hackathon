# Keep this server-side. Never prefix it with NEXT_PUBLIC_.
OPENAI_API_KEY=YOUR_OPEN_API_KEY

# GPT-5.6 Sol alias; override only for an intentional model experiment.
OPENAI_MODEL=gpt-5

# Low is the latency-sensitive default; use medium only after an eval shows a gain.
OPENAI_REASONING_EFFORT=low

# Bound a single model request so the UI cannot wait for the SDK's 10-minute default.
OPENAI_TIMEOUT_MS=240000

# Optional isolated Manim worker. Omit to keep the deterministic SVG lesson fallback.
MANIM_RENDERER_URL=http://127.0.0.1:8787

# Server-only ElevenLabs narration. The defaults use George with Multilingual v2.
ELEVEN_LABS=YOUR_ELEVENLABS_KEY
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
ELEVENLABS_MODEL=eleven_multilingual_v2
